function Cheats:AntiElim(e)
    Settings.AntiElim = e
    if e then
        print("🛡️ Anti-Eliminação ATIVADO!")
        SFX:On()
        local function Protect(char)
            local hum = char:WaitForChild("Humanoid", 5)
            if hum then
                hum.HealthChanged:Connect(function(h)
                    if Settings.AntiElim and h <= 0 then hum.Health = hum.MaxHealth end
                end)
            end
        end
        if lp.Character then Protect(lp.Character) end
        lp.CharacterAdded:Connect(Protect)
    else
        print("🛡️ Anti-Eliminação DESATIVADO!")
        SFX:Off()
    end
end

