-- HACKS AVANÇADOS - DINHEIRO INFINITO
-- ═══════════════════════════════════════════════════════════════════════════════
function Cheats:EnableMoneyHack(e)
    Settings.MoneyHack = e
    if e then
        print("💰 HACK DE DINHEIRO ATIVADO!")
        print("💎 Multiplicador:", MoneyMultiplier, "x")
        SFX:On()
        
        pcall(function()
            local oldNamecall
            oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
                local args = {...}
                local method = getnamecallmethod()
                
                if method == "FireServer" or method == "InvokeServer" then
                    local name = self.Name:lower()
                    
                    if name:find("buy") or name:find("purchase") or name:find("spend") then
                        if Settings.MoneyHack then
                            print("💰 Compra interceptada:", self.Name)
                            spawn(function()
                                for i = 1, MoneyMultiplier do
                                    if Remotes then
                                        local sellRemote = Remotes:FindFirstChild("Sell")
                                        if sellRemote then
                                            pcall(function() sellRemote:FireServer() end)
                                        end
                                    end
                                    wait(0.05)
                                end
                            end)
                            return nil
                        end
                    end
                    
                    if name:find("reward") or name:find("daily") or name:find("coin") then
                        if Settings.MoneyHack then
                            for i = 1, MoneyMultiplier do
                                oldNamecall(self, unpack(args))
                            end
                            print("💰 Recompensa multiplicada por", MoneyMultiplier)
                            return nil
                        end
                    end
                end
                
                return oldNamecall(self, ...)
            end)
        end)
        
        spawn(function()
            while Settings.MoneyHack do
                if Remotes then
                    local daily = Remotes:FindFirstChild("DailyRewardRequest")
                    if daily then
                        pcall(function() daily:FireServer() end)
                    end
                end
                wait(5)
            end
        end)
    else
        print("💰 HACK DE DINHEIRO DESATIVADO!")
        SFX:Off()
    end
end

