local SFX = {}

function SFX:Play(id, vol)
    local s = Instance.new("Sound", SoundService)
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Volume = vol or 0.4
    s:Play()
    game:GetService("Debris"):AddItem(s, 3)
end

function SFX:Hover() self:Play(9114488953, 0.3) end
function SFX:Click() self:Play(9114164197, 0.4) end
function SFX:On() self:Play(9114167985, 0.4) end
function SFX:Off() self:Play(9114168471, 0.4) end
function SFX:Win() self:Play(9114488031, 0.5) end

