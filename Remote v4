-- Tenta múltiplas combinações de argumentos para descobrir qual funciona
local function FireWithVariations(remote, targetPlayer)
    if not remote or not remote.Parent then return false, "Invalid remote" end
    
    local variations = {}
    
    -- Variação 1: Sem argumentos
    table.insert(variations, {})
    
    -- Variação 2: Apenas LocalPlayer
    table.insert(variations, {lp})
    
    -- Variação 3: Nome do player
    table.insert(variations, {lp.Name})
    
    -- Variação 4: UserId
    table.insert(variations, {lp.UserId})
    
    -- Variação 5: Character
    if lp.Character then
        table.insert(variations, {lp.Character})
        
        -- Variação 6: Humanoid
        local hum = lp.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            table.insert(variations, {hum})
        end
        
        -- Variação 7: HumanoidRootPart
        local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            table.insert(variations, {hrp})
            table.insert(variations, {hrp.CFrame})
            table.insert(variations, {hrp.Position})
        end
    end
    
    -- Variação 8: Player + Character
    if lp.Character then
        table.insert(variations, {lp, lp.Character})
    end
    
    -- Variação 9: Booleanos
    table.insert(variations, {true})
    table.insert(variations, {false})
    
    -- Variação 10: Números comuns
    table.insert(variations, {1})
    table.insert(variations, {0})
    table.insert(variations, {999999})
    
    -- Variação 11: Strings comuns
    table.insert(variations, {"admin"})
    table.insert(variations, {"all"})
    table.insert(variations, {"me"})
    
    -- Tenta cada variação
    local lastError = ""
    for i, args in ipairs(variations) do
        if not CheckRate(remote) then continue end
        
        local spoofed = SpoofArgs(args)
        local ok, result = pcall(function()
            if remote:IsA("RemoteEvent") then
                remote:FireServer(unpack(spoofed))
                return "fired"
            else
                return remote:InvokeServer(unpack(spoofed))
            end
        end)
        
        if ok then
            Stats.Fired = Stats.Fired + 1
            Stats.Spoofed = Stats.Spoofed + 1
            if i > 1 then Stats.Accepted = Stats.Accepted + 1 end
            return true, "Variação " .. i .. " funcionou", args
        else
            lastError = tostring(result)
            -- Se erro de permissão, para de tentar
            local errLow = lastError:lower()
            if string.find(errLow, "permission") or string.find(errLow, "unauthorized") 
               or string.find(errLow, "devtools") or string.find(errLow, "267") then
                Stats.Blocked = Stats.Blocked + 1
                return false, "Bloqueado: " .. lastError
            end
        end
        
        if Settings.SafeMode then task.wait(0.02) end
    end
    
    Stats.Errors = Stats.Errors + 1
    return false, "Nenhuma variação funcionou: " .. lastError
end

local function SafeFire(remote, ...)
    if not remote or not remote.Parent then return false end
    if IsForbiddenPath(remote) then Stats.Blocked = Stats.Blocked + 1 return false end
    if IsBlacklisted(remote.Name) then Stats.Blocked = Stats.Blocked + 1 return false end
    
    return FireWithVariations(remote, lp)
end

local function FirePromptSafe(prompt)
    if not prompt or not prompt.Parent then return end
    if IsBlacklisted(prompt.Name) then return end
    
    pcall(function()
        local oldDist = prompt.MaxActivationDistance
        local oldLOS = prompt.RequiresLineOfSight
        local oldHold = prompt.HoldDuration
        
        prompt.MaxActivationDistance = 999999
        prompt.RequiresLineOfSight = false
        prompt.HoldDuration = 0
        
        task.wait(0.01)
        pcall(function() prompt:InputHoldBegin() end)
        task.wait(0.02)
        pcall(function() prompt:InputHoldEnd() end)
        if fireproximityprompt then pcall(function() fireproximityprompt(prompt) end) end
        
        task.wait(0.02)
        prompt.MaxActivationDistance = oldDist
        prompt.RequiresLineOfSight = oldLOS
        prompt.HoldDuration = oldHold
    end)
    
    Stats.Fired = Stats.Fired + 1
    if Settings.SafeMode then task.wait(Settings.Delay) end
end

local function FireClickSafe(detector)
    if not detector or not detector.Parent then return end
    if IsBlacklisted(detector.Name) then return end
    
    pcall(function()
        local old = detector.MaxActivationDistance
        detector.MaxActivationDistance = 999999
        task.wait(0.01)
        if fireclickdetector then pcall(function() fireclickdetector(detector) end) end
        task.wait(0.02)
        detector.MaxActivationDistance = old
    end)
    
    Stats.Fired = Stats.Fired + 1
    if Settings.SafeMode then task.wait(Settings.Delay) end
end

