-- Detecta serviço raiz
local function GetRootService(obj)
    local cur = obj
    for _ = 1, 30 do
        if not cur or not cur.Parent then break end
        if cur.Parent == game then return cur.Name end
        cur = cur.Parent
    end
    return "Unknown"
end

-- Varre todos os remotes
local function ScanAllRemotesForReport()
    local results = {}
    local seen = {}
    
    local function CheckAndAdd(obj)
        if seen[obj] then return end
        if not (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) then return end
        if IsForbiddenPath(obj) then return end
        seen[obj] = true
        
        local low = obj.Name:lower()
        local matched_tag, matched_icon, matched_desc = "MISC", "📡", "Remote genérico"
        
        for _, cat in ipairs(REPORT_CATEGORIES) do
            for _, kw in ipairs(cat.kw) do
                if string.find(low, kw, 1, true) then
                    matched_tag = cat.tag
                    matched_icon = cat.icon
                    matched_desc = cat.desc
                    break
                end
            end
            if matched_tag ~= "MISC" then break end
        end
        
        local svc = GetRootService(obj)
        table.insert(results, {
            name = obj.Name,
            fullpath = obj:GetFullName(),
            service = svc,
            remote = obj,
            isFunc = obj:IsA("RemoteFunction"),
            tag = matched_tag,
            icon = matched_icon,
            desc = matched_desc
        })
    end
    
    -- Varre todos os serviços
    local services = {"ReplicatedStorage", "Workspace", "Players", "Chat", "Teams",
                      "StarterGui", "StarterPack", "StarterPlayer", "SoundService",
                      "Lighting", "CoreGui"}
    
    for _, svcName in ipairs(services) do
        pcall(function()
            local svc = game:GetService(svcName)
            if svc then
                for _, d in ipairs(svc:GetDescendants()) do CheckAndAdd(d) end
            end
        end)
    end
    
    pcall(function()
        for _, d in ipairs(lp:WaitForChild("PlayerGui"):GetDescendants()) do CheckAndAdd(d) end
    end)
    
    -- Ordena: tagged primeiro, depois alfabético
    table.sort(results, function(a, b)
        local aHasTag = a.tag ~= "MISC"
        local bHasTag = b.tag ~= "MISC"
        if aHasTag ~= bHasTag then return aHasTag end
        return a.name < b.name
    end)
    
    return results
end

