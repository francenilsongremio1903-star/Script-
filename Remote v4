            if seen[obj] then return end
            if not (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) then return end
            if IsForbiddenPath(obj) then return end
            
            seen[obj] = true
            local isSafe, kw = IsBlacklisted(obj.Name)
            
