        for _, svc in ipairs(services) do
            pcall(function()
                local service = game:GetService(svc)
                for _, obj in ipairs(service:GetDescendants()) do Add(obj, svc) end
            end)
        end
        
        table.sort(found, function(a, b) if a.Safe ~= b.Safe then return a.Safe end return a.Name < b.Name end)
        ScannedRemotes = found
        
        Notify("🔍 " .. #found .. " remotes encontrados!", Color3.fromRGB(99, 102, 241))
