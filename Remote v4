                Location = location,
                Type = obj:IsA("RemoteFunction") and "RF" or "RE",
                Object = obj,
                Safe = not isSafe
            })
        end
        
        pcall(function() for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do Add(obj, "ReplicatedStorage") end end)
